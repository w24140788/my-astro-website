---
const { title } = Astro.props;
---
<html lang="zh-cn">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<nav style="background: #333; padding: 1rem;">
			<a href="/" style="color: white; margin-right: 20px; text-decoration: none;">首页</a>
			<a href="/about/" style="color: white; text-decoration: none;">关于我</a>
		</nav>

		<main style="padding: 20px;">
			<slot /> <!-- 这里是放页面内容的地方 -->
		</main>

		<footer style="margin-top: 50px; border-top: 1px solid #ccc; padding: 20px;">
			<p>© 2024 我的 GitHub 同步网站</p>
		</footer>
	</body>
</html>

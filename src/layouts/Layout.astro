---
// 1. 这里是【代码围栏】，处理逻辑和接收参数
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <!-- 新的扁平化导航栏：移动端使用滑出抽屉，桌面端为水平导航 -->
    <header class="site-header">
      <div class="nav-inner">
        <a href="/" class="logo">我的网站</a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation" />
        <label for="nav-toggle" class="hamburger" aria-label="打开菜单">☰</label>
        <nav class="nav-links" aria-label="Main navigation">
          <a href="/" class="nav-link">首页</a>
          <a href="/about/" class="nav-link">关于我</a>
        </nav>
      </div>
    </header>

    <!-- 3. 页面主体内容：由 slot 注入 -->
    <main>
      <slot />
    </main>

    <!-- 4. 页脚 -->
    <footer>
      <p>© 2024 由 Astro 构建并同步至 GitHub</p>
    </footer>

    <!-- 5. 样式表：负责美化 -->
    <style is:global>
      /* 基础重置 */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

  :root {
        --color-brand: #1e90ff;
        --color-accent: #ff4d98;
        --bg: #f9f9f9;
        --text: #333;
        --nav-gradient: linear-gradient(135deg, #1f2a53 0%, #1e90ff 40%, #ff4d98 100%);
        --white: #fff;
        --radius: 8px;
        --space: 16px;
        --shadow: 0 2px 10px rgba(0,0,0,.08);
        --transition: 200ms;
      }

      body {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        line-height: 1.6;
        color: var(--text);
        background: var(--bg);
      }

      /* 导航栏样式：固定在顶部，响应式滑出抽屉 */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--nav-gradient);
        color: white;
        border-bottom: 1px solid rgba(0,0,0,.08);
      }

      .nav-inner {
        max-width: 1000px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        height: 64px;
      }

      .logo {
        font-weight: 700;
        color: #fff;
        text-decoration: none;
        letter-spacing: .5px;
      }

      .nav-links {
        display: flex;
        gap: 28px;
      }

      .nav-link {
        color: #d1d5db;
        text-decoration: none;
        padding: 8px 0;
        transition: color var(--transition);
      }

      .nav-link[aria-current="page"] {
        color: #fff;
        border-bottom: 2px solid #fff;
      }

      .nav-toggle { display: none; }
      .hamburger { display: none; color: #fff; font-size: 1.6rem; padding: 0 8px; cursor: pointer; }

        @media (max-width: 800px) {
        .hamburger { display: inline-block; }
        .nav-links {
          position: fixed;
          left: 0;
          top: 64px;
          width: 100%;
          height: calc(100% - 64px);
          background: var(--nav-gradient);
          display: flex;
          flex-direction: column;
          padding: 16px;
          gap: 8px;
          transform: translateX(-100%);
          transition: transform var(--transition);
        }
        #nav-toggle:checked ~ .nav-links {
          transform: translateX(0);
        }
        .nav-toggle { position: absolute; left: -9999px; width: 1px; height: 1px; }
        .nav-links .nav-link {
          padding: 12px 8px;
          width: 100%;
          color: #ddd;
          border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .nav-links .nav-link[aria-current="page"] { border-bottom: none; }
      }

      /* 主体内容区域 */
      main {
        max-width: 800px;
        margin: 40px auto;
        padding: 0 20px;
        min-height: 70vh; /* 保证页面不够长时页脚也在底部 */
      }

      footer {
        text-align: center;
        padding: 40px 0;
        color: #888;
        border-top: 1px solid #eee;
      }

      h1 { margin-bottom: 20px; color: #111; }
    </style>
  </body>
</html>
